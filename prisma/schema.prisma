generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  cpf               String             @unique
  email             String
  password          String
  refresh_token     RefreshToken?
  password_token    PasswordToken?
  show_ad           ShowAd?
  pushTokens        PushToken[]
  userNotifications UserNotification[]  // ← nova relação
  email_change      EmailChange?

  @@map("users")
}

model Emails {
  id            String @id @default(uuid())
  censoredEmail String
  email         String

  @@map("emails")
}

model RefreshToken {
  id        String @id @default(uuid())
  expiresIn Int
  user      User   @relation(fields: [userId], references: [id])
  userId    String @unique

  @@map("refresh_token")
}

// Troca de e-mail da conta do app pendente de confirmação por código (enviado
// ao novo e-mail). Uma pendência por usuário; expira e é consumida na confirmação.
model EmailChange {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  newEmail  String
  code      String
  expiresIn DateTime
  createdAt DateTime @default(now())

  @@map("email_changes")
}

model PasswordToken {
  id        String   @id @default(uuid())
  expiresIn DateTime
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique

  @@map("password_token")
}

model ShowAd {
  id        String   @id @default(uuid())
  expiresIn DateTime
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  show      Boolean  @default(true)

  @@map("show_ad")
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("push_tokens")
}

model Notification {
  id                 String             @id @default(uuid())
  title              String
  body               String?
  data               Json?
  status             String             @default("pending")
  tokens             Int                @default(0)
  receipts           Json?              
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  userNotifications  UserNotification[] 

  @@index([createdAt])
  @@map("notifications")
}

model UserMetadata {
  userId      String   @id
  hasOpenBill Boolean  @default(false)
  address     String?
  updatedAt   DateTime @updatedAt

  @@map("user_metadata")
}

model UserNotification {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  notification   Notification @relation(fields: [notificationId], references: [id])
  notificationId String
  read           Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@map("user_notifications")
  @@index([userId])
  @@index([notificationId])
}

// ─── App Messages ────────────────────────────────────────────────────────────

enum TargetingType {
  GLOBAL
  CLIENTE
  CIDADE
  BAIRRO_CIDADE
  RUA
  CEP
  CEP_NUMERO
}

model AppMessage {
  id          String             @id @default(uuid())
  title       String
  msg_cliente String             @db.Text
  timeout_sec Int                @default(10)
  active      Boolean            @default(true)
  deleted_at  DateTime?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  targets     AppMessageTarget[]

  @@index([active, deleted_at])
  @@map("app_messages")
}

model AppMessageTarget {
  id              String        @id @default(uuid())
  message         AppMessage    @relation(fields: [messageId], references: [id])
  messageId       String
  targeting_type  TargetingType
  targeting_value String        @default("*")

  @@index([targeting_type, targeting_value])
  @@map("app_message_targets")
}

model ClientAddress {
  id         String   @id @default(uuid())
  cpf        String   @unique
  cidade     String?
  bairro     String?
  cep        String?
  numero     String?
  updated_at DateTime @updatedAt

  @@index([cep])
  @@map("client_addresses")
}

// ─── Speedtest nativo ────────────────────────────────────────────────────────
// Um registro por teste concluído/abortado no app. O app mede no cliente
// (src/speedtest/engine.ts) e envia o resultado detalhado para POST /speedtest/result.

model SpeedTest {
  id     String  @id @default(uuid())

  // Identificação do cliente (do JWT, quando autenticado)
  userId String?
  cpf    String?

  // Resultados principais
  downloadMbps Float? // vazão de download (Mbit/s)
  uploadMbps   Float? // vazão de upload (Mbit/s)
  pingMs       Float? // latência média (ms)
  jitterMs     Float? // variação da latência (ms)
  packetLoss   Float? // perda de pacotes (0-100 %), se medida

  // Fase de download
  downloadBytes       Float? // bytes transferidos na janela de medição
  downloadDurationMs  Int?   // duração efetiva da medição de download
  downloadConnections Int?   // conexões paralelas usadas

  // Fase de upload
  uploadBytes       Float?
  uploadDurationMs  Int?
  uploadConnections Int?

  // Ping
  pingSamplesCount Int?
  pingSamples      Json? // array bruto de amostras (ms)

  // Contexto do cliente / dispositivo
  appVersion     String?
  platform       String? // ios | android | web
  osVersion      String?
  deviceModel    String?
  connectionType String? // wifi | cellular | ethernet | unknown
  carrier        String? // operadora móvel, quando aplicável

  // Contexto capturado no servidor
  clientIp   String?
  userAgent  String? @db.Text
  serverHost String? // base URL do speedtest usada pelo app

  // Metadados de execução
  status       String    @default("completed") // completed | aborted | error
  errorMessage String?   @db.Text
  config       Json?     // DEFAULT_CONFIG efetivo usado no teste
  raw          Json?     // payload extra do engine, para não perder nada
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([cpf])
  @@index([userId])
  @@index([createdAt])
  @@index([cpf, createdAt])
  @@map("speed_tests")
}
