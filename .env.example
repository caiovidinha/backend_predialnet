CLIENT_ID=
CLIENT_SECRET=
URL=http://localhost:3333
PORT=3333
NODE_ENV="development"
DATABASE_URL=""

PUSH_AUTH_TOKEN=token
SWAGGER_TOKEN=meu_token_seguro

ACCESS_TOKEN_SECRET=""
REFRESH_TOKEN_SECRET=""

API_LOGIN=""
API_PASS=""

APISAPO_TOKEN=
APISAPO_URL=https://apisapo.intranet.com.br/v1
APISAPO_TIMEOUT_MS=30000
# Origens permitidas no CORS do endpoint /eh-cliente (separar por vírgula para múltiplas)
ACTIVATION_SITE_ORIGIN=https://www.predialnet.com.br

MIN_APP_VERSION=2.0.9
LATEST_APP_VERSION=2.0.9

# Feature flag: habilita autenticação JWT nos endpoints protegidos
# false = comportamento legado (sem JWT), true = JWT obrigatório
ENABLE_JWT=false

# Chamados de suporte
# Destino da notificação de novo chamado (padrão: caiomdavidinha@gmail.com)
SUPPORT_NOTIFY_EMAIL=
# Limite por anexo em MB (padrão 25)
TICKET_MAX_UPLOAD_MB=25

# Object storage (anexos) — S3-compatível (Cloudflare R2 / Backblaze B2 / AWS S3 / MinIO)
# Ex.: Cloudflare R2 → S3_REGION=auto e S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
# Validade (segundos) da URL de download assinada (padrão 300)
S3_URL_TTL_SEC=300